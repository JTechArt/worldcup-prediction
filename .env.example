# =============================================================================
# World Cup 2026 Prediction Game — Environment Variables
# Copy to .env and fill in values, then: docker compose up --build
# =============================================================================

# ── Integration feature flags ──────────────────────────────────────────────
# Set these to true once you have the credentials configured below.
# When false, the component starts but logs intent only (no external calls).
MAIL_ENABLED=false
FOOTBALL_API_ENABLED=false

# ── Database mode (choose one) ─────────────────────────────────────────────
# SQLite (default — zero external deps):
APP_PROFILE=sqlite
SQLITE_PATH=/data/worldcup.db

# PostgreSQL (production — use docker-compose.postgres.yml):
# APP_PROFILE=postgres
# DB_USERNAME=worldcup
# DB_PASSWORD=change_me_in_production

# ── OAuth2 — required for login ────────────────────────────────────────────
# Without these the app starts (login page loads) but sign-in won't work.
# Get credentials from Google Cloud Console and LinkedIn Developer Portal.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# ── Football Data API ──────────────────────────────────────────────────────
# Required only when FOOTBALL_API_ENABLED=true.
# Free key at https://www.football-data.org/client/register
FOOTBALL_API_KEY=

# ── Email / SMTP ───────────────────────────────────────────────────────────
# Required only when MAIL_ENABLED=true.
# Use any SMTP provider (e.g. SendGrid, Mailgun, Gmail SMTP).
# Set via Spring environment variable override style:
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com
