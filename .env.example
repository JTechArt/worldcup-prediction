# =============================================================================
# World Cup 2026 Prediction Game — Environment Variables
# Copy to .env and fill in values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# Database mode (choose one)
# -----------------------------------------------------------------------------
# SQLite (default — no external DB needed, just run docker compose up):
APP_PROFILE=sqlite
SQLITE_PATH=/data/worldcup.db

# PostgreSQL (production — use docker-compose.postgres.yml):
# APP_PROFILE=postgres
# DATABASE_URL=jdbc:postgresql://db:5432/worldcup
# DATABASE_USERNAME=worldcup
# DATABASE_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# OAuth2 — required for login (both SQLite and PostgreSQL modes)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# -----------------------------------------------------------------------------
# Football API — optional, enables automatic result sync
# Leave empty to use admin manual entry only
# -----------------------------------------------------------------------------
FOOTBALL_API_KEY=

# -----------------------------------------------------------------------------
# Email / SMTP — optional, enables email notifications
# Leave empty to use log-only mode
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
